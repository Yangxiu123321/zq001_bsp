+int imx577_i2c_exit(VI_PIPE ViPipe)
+{
+	if (g_fd[ViPipe] >= 0) {
+		close(g_fd[ViPipe]);
+		g_fd[ViPipe] = -1;
+		return CVI_SUCCESS;
+	}
+	return CVI_FAILURE;
+}
+
+int imx577_read_register(VI_PIPE ViPipe, int addr)
+{
+	int ret, data;
+	CVI_U8 buf[8];
+	CVI_U8 idx = 0;
+
+	if (g_fd[ViPipe] < 0)
+		return CVI_FAILURE;
+
+	if (imx577_addr_byte == 2)
+		buf[idx++] = (addr >> 8) & 0xff;
+
+	// add address byte 0
+	buf[idx++] = addr & 0xff;
+
+	ret = write(g_fd[ViPipe], buf, imx577_addr_byte);
+	if (ret < 0) {
+		CVI_TRACE_SNS(CVI_DBG_ERR, "I2C_WRITE error!\n");
+		return ret;
+	}
+
+	buf[0] = 0;
+	buf[1] = 0;
+	ret = read(g_fd[ViPipe], buf, imx577_data_byte);
+	if (ret < 0) {
+		CVI_TRACE_SNS(CVI_DBG_ERR, "I2C_READ error!\n");
+		return ret;
+	}
+
+	// pack read back data
+	data = 0;
+	if (imx577_data_byte == 2) {
+		data = buf[0] << 8;
+		data += buf[1];
+	} else {
+		data = buf[0];
+	}
+
+	syslog(LOG_DEBUG, "i2c r 0x%x = 0x%x\n", addr, data);
+	return data;
+}
+
+
+int imx577_write_register(VI_PIPE ViPipe, int addr, int data)
+{
+	CVI_U8 idx = 0;
+	int ret;
+	CVI_U8 buf[8];
+
+	if (g_fd[ViPipe] < 0)
+		return CVI_SUCCESS;
+
+	if (imx577_addr_byte == 2) {
+		buf[idx] = (addr >> 8) & 0xff;
+		idx++;
+		buf[idx] = addr & 0xff;
+		idx++;
+	}
+
+	if (imx577_data_byte == 1) {
+		buf[idx] = data & 0xff;
+		idx++;
+	}
+
+	ret = write(g_fd[ViPipe], buf, imx577_addr_byte + imx577_data_byte);
+	if (ret < 0) {
+		CVI_TRACE_SNS(CVI_DBG_ERR, "I2C_WRITE 0x%x error!\n", addr);
+		return CVI_FAILURE;
+	}
+	syslog(LOG_DEBUG, "i2c w 0x%x 0x%x\n", addr, data);
+	return CVI_SUCCESS;
+}
+
+static void delay_ms(int ms)
+{
+	usleep(ms * 1000);
+}
+
+void imx577_standby(VI_PIPE ViPipe)
+{
+	(void)(ViPipe);
+}
+
+void imx577_restart(VI_PIPE ViPipe)
+{
+	(void)(ViPipe);
+	delay_ms(20);
+}
+
+void imx577_default_reg_init(VI_PIPE ViPipe)
+{
+	CVI_U32 i;
+	return;
+	for (i = 0; i < g_pastImx577[ViPipe]->astSyncInfo[0].snsCfg.u32RegNum; i++) {
+	imx577_write_register(ViPipe,
+				g_pastImx577[ViPipe]->astSyncInfo[0].snsCfg.astI2cData[i].u32RegAddr,
+				g_pastImx577[ViPipe]->astSyncInfo[0].snsCfg.astI2cData[i].u32Data);
+	}
+}
+
+
+void imx577_mirror_flip(VI_PIPE ViPipe, ISP_SNS_MIRRORFLIP_TYPE_E eSnsMirrorFlip)
+{
+	CVI_U8 val = 0;
+
+	val = imx577_read_register(ViPipe, IMX577_ORIEN_ADDR);
+	val &= ~0x3;
+
+	switch (eSnsMirrorFlip) {
+	case ISP_SNS_NORMAL:
+		break;
+	case ISP_SNS_MIRROR:
+		val |= 0x1;
+		break;
+	case ISP_SNS_FLIP:
+		val |= 0x1<<1;
+		break;
+	case ISP_SNS_MIRROR_FLIP:
+		val |= 0x1;
+		val |= 0x1<<1;
+		break;
+	default:
+		return;
+	}
+
+
+	imx577_standby(ViPipe);
+	imx577_write_register(ViPipe, IMX577_ORIEN_ADDR, val);
+	usleep(1000*100);
+	imx577_restart(ViPipe);
+}
+
+int imx577_probe(VI_PIPE ViPipe)
+{
+	int nVal_h, nVal_l;
+
+	usleep(100);
+	if (imx577_i2c_init(ViPipe) != CVI_SUCCESS)
+		return CVI_FAILURE;
+
+	imx577_write_register(ViPipe, 0x0a02, 0x1f);
+	imx577_write_register(ViPipe, 0x0a00, 0x1);
+	nVal_h = imx577_read_register(ViPipe, IMX577_CHIP_ID_ADDR_H);
+	nVal_l = imx577_read_register(ViPipe, IMX577_CHIP_ID_ADDR_L);
+
+	if (nVal_h < 0 || nVal_l < 0) {
+		CVI_TRACE_SNS(CVI_DBG_ERR, "read sensor id error.\n");
+		return nVal_h;
+	}
+
+	if ((((nVal_h & 0xff) << 4) | ((nVal_l & 0xf0) >> 4)) != IMX577_CHIP_ID) {
+		CVI_TRACE_SNS(CVI_DBG_ERR, "Sensor ID Mismatch! Use the wrong sensor??\n");
+		return CVI_FAILURE;
+	}
+
+	return CVI_SUCCESS;
+}
+
+void imx577_init(VI_PIPE ViPipe)
+{
+	WDR_MODE_E        enWDRMode;
+	CVI_U8            u8ImgMode;
+
+	enWDRMode   = g_pastImx577[ViPipe]->enWDRMode;
+	u8ImgMode   = g_pastImx577[ViPipe]->u8ImgMode;
+
+	imx577_i2c_init(ViPipe);
+
+	if (enWDRMode == WDR_MODE_2To1_LINE) {
+		if (u8ImgMode == IMX577_MODE_12M20_WDR)
+			imx577_wdr_12m20_2to1_init(ViPipe);
+		else{
+		}
+	} else {
+		if (u8ImgMode == IMX577_MODE_12M20) {
+			imx577_linear_12m20_init(ViPipe);
+		}
+		else if (u8ImgMode == IMX577_MODE_MASTER_12M20) {
+			imx577_linear_master_12m20_init(ViPipe);
+		} else if (u8ImgMode == IMX577_MODE_SLAVE_12M20) {
+			imx577_linear_slave_12m20_init(ViPipe);
+		}
+	}
+	g_pastImx577[ViPipe]->bInit = CVI_TRUE;
+}
