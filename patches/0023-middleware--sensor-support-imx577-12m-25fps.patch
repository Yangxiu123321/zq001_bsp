+
+	switch (u8Mode) {
+	case WDR_MODE_NONE:
+		if (pstSnsState->u8ImgMode == IMX577_MODE_12M20_WDR)
+			pstSnsState->u8ImgMode = IMX577_MODE_12M20;
+		else {
+		}
+		pstSnsState->enWDRMode = WDR_MODE_NONE;
+		pstSnsState->u32FLStd = g_astImx577_mode[pstSnsState->u8ImgMode].u32VtsDef;
+		syslog(LOG_INFO, "WDR_MODE_NONE\n");
+		break;
+	default:
+		CVI_TRACE_SNS(CVI_DBG_ERR, "Unknown mode!\n");
+		return CVI_FAILURE;
+	}
+
+	pstSnsState->au32FL[0] = pstSnsState->u32FLStd;
+	pstSnsState->au32FL[1] = pstSnsState->au32FL[0];
