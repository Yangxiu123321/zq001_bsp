diff --git a/v1/component/isp/sensor/cv182x/sony_imx577/Makefile b/v1/component/isp/sensor/cv182x/sony_imx577/Makefile
new file mode 100755
index 000000000..de0bf1c01
--- /dev/null
+++ b/v1/component/isp/sensor/cv182x/sony_imx577/Makefile
@@ -0,0 +1,36 @@
+SHELL = /bin/bash
+ifeq ($(PARAM_FILE), )
+	PARAM_FILE=../../../../../../$(shell echo $(MW_VER))/Makefile.param
+	include $(PARAM_FILE)
+endif
+
+SDIR = $(PWD)
+SRCS = $(wildcard $(SDIR)/*.c)
+INCS = -I$(MW_INC) -I$(ISP_INC) -I$(VI_INC) -I$(KERNEL_INC) -I$(VI_INC) -I./include
+OBJS = $(SRCS:.c=.o)
+DEPS = $(SRCS:.c=.d)
+TARGET_A = $(MW_LIB)/libsns_imx577.a
+TARGET_SO = $(MW_LIB)/libsns_imx577.so
+
+EXTRA_CFLAGS = $(INCS)
+EXTRA_LDFLAGS =
+
+.PHONY : clean all
+all : $(TARGET_A) $(TARGET_SO)
+
+$(SDIR)/%.o: $(SDIR)/%.c
+	@$(CC) $(DEPFLAGS) $(CFLAGS) $(EXTRA_CFLAGS) -c $< -o $@
+	@echo [$(notdir $(CC))] $(notdir $@)
+
+$(TARGET_A): $(OBJS)
+	@$(AR) $(ARFLAGS) $@ $(OBJS)
+	@echo -e $(YELLOW)[LINK]$(END)[$(notdir $(AR))] $(notdir $(TARGET_A))
+
+$(TARGET_SO): $(OBJS)
+	@$(LD) $(LDFLAGS) $(EXTRA_LDFLAGS) -o $@ --start-group $(OBJS) --end-group
+	@echo -e $(GREEN)[LINK]$(END)[$(notdir $(LD))] $(notdir $(TARGET_SO))
+
+clean:
+	@rm -f $(OBJS) $(DEPS) $(TARGET_A) $(TARGET_SO)
+
+-include $(DEPS)
diff --git a/v1/component/isp/sensor/cv182x/sony_imx577/imx577_cmos.c b/v1/component/isp/sensor/cv182x/sony_imx577/imx577_cmos.c
new file mode 100755
index 000000000..61a76b02e
--- /dev/null
+++ b/v1/component/isp/sensor/cv182x/sony_imx577/imx577_cmos.c
@@ -0,0 +1,1159 @@
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <assert.h>
+#include <syslog.h>
+#include <errno.h>
+#ifdef ARCH_CV182X
+#include "cvi_type.h"
+#include "cvi_comm_video.h"
+#include <linux/cvi_vip_snsr.h>
+#else
+#include <cvi_type.h>
+#include <cvi_comm_video.h>
+#endif
+#include "cvi_debug.h"
+#include "cvi_comm_sns.h"
+#include "cvi_sns_ctrl.h"
+#include "cvi_ae_comm.h"
+#include "cvi_awb_comm.h"
+#include "cvi_ae.h"
+#include "cvi_awb.h"
+#include "cvi_isp.h"
+
+
+#include "imx577_cmos_ex.h"
+#include "imx577_cmos_param.h"
+
+#define DIV_0_TO_1(a)   ((0 == (a)) ? 1 : (a))
+#define DIV_0_TO_1_FLOAT(a) ((((a) < 1E-10) && ((a) > -1E-10)) ? 1 : (a))
+#define IMX577_ID 0x0577
+
+#define IMX577_I2C_ADDR_IS_VALID(addr)      ((addr) == IMX577_I2C_ADDR_1 || (addr) == IMX577_I2C_ADDR_2)
+/****************************************************************************
+ * global variables                                                            *
+ ****************************************************************************/
+
+ISP_SNS_STATE_S *g_pastImx577[VI_MAX_PIPE_NUM] = {CVI_NULL};
+SNS_COMBO_DEV_ATTR_S* g_pastImx577ComboDevArray[VI_MAX_PIPE_NUM] = {CVI_NULL};
+
+#define IMX577_SENSOR_GET_CTX(dev, pstCtx)   (pstCtx = g_pastImx577[dev])
+#define IMX577_SENSOR_SET_CTX(dev, pstCtx)   (g_pastImx577[dev] = pstCtx)
+#define IMX577_SENSOR_RESET_CTX(dev)         (g_pastImx577[dev] = CVI_NULL)
+#define IMX577_SENSOR_SET_COMBO(dev, pstCtx)   (g_pastImx577ComboDevArray[dev] = pstCtx)
+#define IMX577_SENSOR_GET_COMBO(dev, pstCtx)   (pstCtx = g_pastImx577ComboDevArray[dev])
+
+#define IMX577_SNNSOR_IS_1L() (imx577_rx_attr.mipi_attr.lane_id[2] == -1 && imx577_rx_attr.mipi_attr.lane_id[4] == -1)
+#define IMX577_SNNSOR_IS_2L() (imx577_rx_attr.mipi_attr.lane_id[3] == -1 && imx577_rx_attr.mipi_attr.lane_id[4] == -1)
+#define IMX577_SNNSOR_IS_4L() (imx577_rx_attr.mipi_attr.lane_id[3] != -1 && imx577_rx_attr.mipi_attr.lane_id[4] != -1)
+
+ISP_SNS_COMMBUS_U g_aunImx577_BusInfo[VI_MAX_PIPE_NUM] = {
+	[0] = { .s8I2cDev = 0},
+	[1 ... VI_MAX_PIPE_NUM - 1] = { .s8I2cDev = -1}
+};
+
+ISP_SNS_COMMADDR_U g_aunImx577_AddrInfo[VI_MAX_PIPE_NUM] = {
+	[0] = { .s8I2cAddr = 0},
+	[1 ... VI_MAX_PIPE_NUM - 1] = { .s8I2cAddr = -1}
+};
+
+CVI_U16 g_au16Imx577_GainMode[VI_MAX_PIPE_NUM] = {0};
+ISP_SNS_MIRRORFLIP_TYPE_E g_aeImx577_MirrorFip[VI_MAX_PIPE_NUM] = {0};
+
+/****************************************************************************
+ * local variables and functions                                                           *
+ ****************************************************************************/
+static ISP_FSWDR_MODE_E genFSWDRMode[VI_MAX_PIPE_NUM] = {
+	[0 ... VI_MAX_PIPE_NUM - 1] = ISP_FSWDR_NORMAL_MODE
+};
+
+// static CVI_U32 gu32MaxTimeGetCnt[VI_MAX_PIPE_NUM] = {0};
+static CVI_U32 g_au32InitExposure[VI_MAX_PIPE_NUM]  = {0};
+static CVI_U32 g_au32LinesPer500ms[VI_MAX_PIPE_NUM] = {0};
+static CVI_U16 g_au16InitWBGain[VI_MAX_PIPE_NUM][3] = {{0} };
+static CVI_U16 g_au16SampleRgain[VI_MAX_PIPE_NUM] = {0};
+static CVI_U16 g_au16SampleBgain[VI_MAX_PIPE_NUM] = {0};
+static CVI_S32 cmos_get_wdr_size(VI_PIPE ViPipe, ISP_SNS_ISP_INFO_S *pstIspCfg);
+/*****Imx577 Lines Range*****/
+#define IMX577_FULL_LINES_MAX  (0xFFFFF)
+#define IMX577_VMAX_12M20_LINEAR	0x1194
+
+/*****Imx577 Register Address*****/
+#define IMX577_HOLD_ADDR		0x0104
+
+#define IMX577_SHR_L_ADDR		0x0203
+#define IMX577_SHR_H_ADDR		0x0202
+
+#define IMX577_AGAIN_L_ADDR		0x0205
+#define IMX577_AGAIN_H_ADDR		0x0204
+#define IMX577_DGAIN_L_ADDR     0x020F
+#define IMX577_DGAIN_H_ADDR	    0x020E
+
+#define IMX577_VMAX_L_ADDR		0x0341
+#define IMX577_VMAX_H_ADDR		0x0340
+
+/*****Imx577 Size*****/
+#define SENSOR_IMX577_12M_WIDTH		4032
+#define SENSOR_IMX577_12M_HEIGHT	3000
+#define IMX577_RES_IS_12M(w, h)      ((w) == SENSOR_IMX577_12M_WIDTH && (h) == SENSOR_IMX577_12M_HEIGHT)
+
+
+static CVI_S32 cmos_get_ae_default(VI_PIPE ViPipe, AE_SENSOR_DEFAULT_S *pstAeSnsDft)
+{
+	ISP_SNS_STATE_S *pstSnsState = CVI_NULL;
+
+	CMOS_CHECK_POINTER(pstAeSnsDft);
+	IMX577_SENSOR_GET_CTX(ViPipe, pstSnsState);
+	CMOS_CHECK_POINTER(pstSnsState);
+
+	pstAeSnsDft->u32FullLinesStd = pstSnsState->u32FLStd;
+	pstAeSnsDft->u32FlickerFreq = 50 * 256;
+	pstAeSnsDft->u32FullLinesMax = IMX577_FULL_LINES_MAX;
+	pstAeSnsDft->u32HmaxTimes = (1000000) / (pstSnsState->u32FLStd * g_astImx577_mode[pstSnsState->u8ImgMode].f32MaxFps);
+
+	pstAeSnsDft->stIntTimeAccu.enAccuType = AE_ACCURACY_LINEAR;
+	pstAeSnsDft->stIntTimeAccu.f32Accuracy = 1;
+	pstAeSnsDft->stIntTimeAccu.f32Offset = 0;
+
+	pstAeSnsDft->stAgainAccu.enAccuType = AE_ACCURACY_TABLE;
+	pstAeSnsDft->stAgainAccu.f32Accuracy = 1;
+
+	pstAeSnsDft->stDgainAccu.enAccuType = AE_ACCURACY_TABLE;
+	pstAeSnsDft->stDgainAccu.f32Accuracy = 1;
+
+	pstAeSnsDft->u32ISPDgainShift = 8;
+	pstAeSnsDft->u32MinISPDgainTarget = 1 << pstAeSnsDft->u32ISPDgainShift;
+	pstAeSnsDft->u32MaxISPDgainTarget = 2 << pstAeSnsDft->u32ISPDgainShift;
+
+	if (g_au32LinesPer500ms[ViPipe] == 0)
+		pstAeSnsDft->u32LinesPer500ms = pstSnsState->u32FLStd * g_astImx577_mode[pstSnsState->u8ImgMode].f32MaxFps / 2;
+	else
+		pstAeSnsDft->u32LinesPer500ms = g_au32LinesPer500ms[ViPipe];
+	pstAeSnsDft->u32SnsStableFrame = 8;
+
+	switch (pstSnsState->enWDRMode) {
+	default:
+	case WDR_MODE_NONE:   /*linear mode*/
+		pstAeSnsDft->f32Fps = g_astImx577_mode[pstSnsState->u8ImgMode].f32MaxFps;
+		pstAeSnsDft->f32MinFps = g_astImx577_mode[pstSnsState->u8ImgMode].f32MinFps;
+		pstAeSnsDft->au8HistThresh[0] = 0xd;
+		pstAeSnsDft->au8HistThresh[1] = 0x28;
+		pstAeSnsDft->au8HistThresh[2] = 0x60;
+		pstAeSnsDft->au8HistThresh[3] = 0x80;
+
+		pstAeSnsDft->u32MaxAgain = g_astImx577_mode[pstSnsState->u8ImgMode].stAgain[0].u32Max;
+		pstAeSnsDft->u32MinAgain = g_astImx577_mode[pstSnsState->u8ImgMode].stAgain[0].u32Min;
+		pstAeSnsDft->u32MaxAgainTarget = pstAeSnsDft->u32MaxAgain;
+		pstAeSnsDft->u32MinAgainTarget = pstAeSnsDft->u32MinAgain;
+
+		pstAeSnsDft->u32MaxDgain = g_astImx577_mode[pstSnsState->u8ImgMode].stDgain[0].u32Max;
+		pstAeSnsDft->u32MinDgain = g_astImx577_mode[pstSnsState->u8ImgMode].stDgain[0].u32Min;
+		pstAeSnsDft->u32MaxDgainTarget = pstAeSnsDft->u32MaxDgain;
+		pstAeSnsDft->u32MinDgainTarget = pstAeSnsDft->u32MinDgain;
+
+		pstAeSnsDft->u8AeCompensation = 40;
+		pstAeSnsDft->u32InitAESpeed = 64;
+		pstAeSnsDft->u32InitAETolerance = 5;
+		pstAeSnsDft->u32AEResponseFrame = 4;
+		pstAeSnsDft->enAeExpMode = AE_EXP_HIGHLIGHT_PRIOR;
+		pstAeSnsDft->u32InitExposure = g_au32InitExposure[ViPipe] ? g_au32InitExposure[ViPipe] : 76151;
+
+		//shutter time [9 to (number of lines perframe -1)]
+		pstAeSnsDft->u32MaxIntTime = g_astImx577_mode[pstSnsState->u8ImgMode].stExp[0].u16Max;
+		pstAeSnsDft->u32MinIntTime = g_astImx577_mode[pstSnsState->u8ImgMode].stExp[0].u16Min;
+		pstAeSnsDft->u32MaxIntTimeTarget = 65535;
+		pstAeSnsDft->u32MinIntTimeTarget = 1;
+		break;
+
+	case WDR_MODE_2To1_LINE:
+		pstAeSnsDft->f32Fps = g_astImx577_mode[pstSnsState->u8ImgMode].f32MaxFps;
+		pstAeSnsDft->f32MinFps = g_astImx577_mode[pstSnsState->u8ImgMode].f32MinFps;
+		pstAeSnsDft->au8HistThresh[0] = 0xC;
+		pstAeSnsDft->au8HistThresh[1] = 0x18;
+		pstAeSnsDft->au8HistThresh[2] = 0x60;
+		pstAeSnsDft->au8HistThresh[3] = 0x80;
+
+		pstAeSnsDft->u32MaxIntTime = g_astImx577_mode[pstSnsState->u8ImgMode].stExp[1].u16Max;
+		pstAeSnsDft->u32MinIntTime = g_astImx577_mode[pstSnsState->u8ImgMode].stExp[0].u16Min;
+
+		pstAeSnsDft->u32MaxIntTimeTarget = 65535;
+		pstAeSnsDft->u32MinIntTimeTarget = pstAeSnsDft->u32MinIntTime;
+
+		pstAeSnsDft->u32MaxAgain = g_astImx577_mode[pstSnsState->u8ImgMode].stAgain[0].u32Max;
+		pstAeSnsDft->u32MinAgain = g_astImx577_mode[pstSnsState->u8ImgMode].stAgain[0].u32Min;
+		pstAeSnsDft->u32MaxAgainTarget = pstAeSnsDft->u32MaxAgain;
+		pstAeSnsDft->u32MinAgainTarget = pstAeSnsDft->u32MinAgain;
+
+		pstAeSnsDft->u32MaxDgain = g_astImx577_mode[pstSnsState->u8ImgMode].stDgain[0].u32Max;
+		pstAeSnsDft->u32MinDgain = g_astImx577_mode[pstSnsState->u8ImgMode].stDgain[0].u32Min;
+		pstAeSnsDft->u32MaxDgainTarget = pstAeSnsDft->u32MaxDgain;
+		pstAeSnsDft->u32MinDgainTarget = pstAeSnsDft->u32MinDgain;
+		pstAeSnsDft->u32MaxISPDgainTarget = 16 << pstAeSnsDft->u32ISPDgainShift;
+
+		pstAeSnsDft->u32InitExposure = g_au32InitExposure[ViPipe] ? g_au32InitExposure[ViPipe] : 52000;
+		pstAeSnsDft->u32InitAESpeed = 64;
+		pstAeSnsDft->u32InitAETolerance = 5;
+		pstAeSnsDft->u32AEResponseFrame = 4;
+		if (genFSWDRMode[ViPipe] == ISP_FSWDR_LONG_FRAME_MODE) {
+			pstAeSnsDft->u8AeCompensation = 64;
+			pstAeSnsDft->enAeExpMode = AE_EXP_HIGHLIGHT_PRIOR;
+		} else {
+			pstAeSnsDft->u8AeCompensation = 40;
+			pstAeSnsDft->enAeExpMode = AE_EXP_LOWLIGHT_PRIOR;
+		}
+		break;
+	}
+
+	return CVI_SUCCESS;
+}
+
+static CVI_S32 cmos_fps_set(VI_PIPE ViPipe, CVI_FLOAT f32Fps, AE_SENSOR_DEFAULT_S *pstAeSnsDft)
+{
+	ISP_SNS_STATE_S *pstSnsState = CVI_NULL;
+	CVI_U32 u32VMAX = IMX577_VMAX_12M20_LINEAR;
+	CVI_FLOAT f32MaxFps = 0;
+	CVI_FLOAT f32MinFps = 0;
+	CVI_U32 u32Vts = 0;
+	ISP_SNS_REGS_INFO_S *pstSnsRegsInfo = CVI_NULL;
+
+	CMOS_CHECK_POINTER(pstAeSnsDft);
+	IMX577_SENSOR_GET_CTX(ViPipe, pstSnsState);
+	CMOS_CHECK_POINTER(pstSnsState);
+
+	u32Vts = g_astImx577_mode[pstSnsState->u8ImgMode].u32VtsDef;
+	pstSnsRegsInfo = &pstSnsState->astSyncInfo[0].snsCfg;
+	f32MaxFps = g_astImx577_mode[pstSnsState->u8ImgMode].f32MaxFps;
+	f32MinFps = g_astImx577_mode[pstSnsState->u8ImgMode].f32MinFps;
+
+	switch (pstSnsState->u8ImgMode) {
+
+	case IMX577_MODE_12M20:
+		if ((f32Fps <= f32MaxFps) && (f32Fps >= f32MinFps)) {
+			u32VMAX = u32Vts * f32MaxFps / DIV_0_TO_1_FLOAT(f32Fps);
+		} else {
+			CVI_TRACE_SNS(CVI_DBG_ERR, "Unsupport Fps: %f\n", f32Fps);
+			return CVI_FAILURE;
+		}
+		u32VMAX = (u32VMAX > IMX577_FULL_LINES_MAX) ? IMX577_FULL_LINES_MAX : u32VMAX;
+		break;
+	case IMX577_MODE_MASTER_12M20:
+		if ((f32Fps <= f32MaxFps) && (f32Fps >= f32MinFps)) {
+			u32VMAX = u32Vts * f32MaxFps / DIV_0_TO_1_FLOAT(f32Fps);
+		} else {
+			CVI_TRACE_SNS(CVI_DBG_ERR, "Unsupport Fps: %f\n", f32Fps);
+			return CVI_FAILURE;
+		}
+		u32VMAX = (u32VMAX > IMX577_FULL_LINES_MAX) ? IMX577_FULL_LINES_MAX : u32VMAX;
+		break;
+	case IMX577_MODE_SLAVE_12M20:
+		if ((f32Fps <= f32MaxFps) && (f32Fps >= f32MinFps)) {
+			u32VMAX = u32Vts * f32MaxFps / DIV_0_TO_1_FLOAT(f32Fps);
+		} else {
+			CVI_TRACE_SNS(CVI_DBG_ERR, "Unsupport Fps: %f\n", f32Fps);
+			return CVI_FAILURE;
+		}
+		u32VMAX = (u32VMAX > IMX577_FULL_LINES_MAX) ? IMX577_FULL_LINES_MAX : u32VMAX;
+		break;
+	default:
+		CVI_TRACE_SNS(CVI_DBG_ERR, "Unsupport sensor mode: %d\n", pstSnsState->u8ImgMode);
+		return CVI_FAILURE;
+	}
+
+	if (pstSnsState->enWDRMode == WDR_MODE_NONE) {
+		pstSnsRegsInfo->astI2cData[LINEAR_VMAX_L].u32Data = (u32VMAX & 0xFF);
+		pstSnsRegsInfo->astI2cData[LINEAR_VMAX_H].u32Data = ((u32VMAX & 0xFF00) >> 8);
+	} else {
+		CVI_TRACE_SNS(CVI_DBG_ERR, "Unsupport wdr mode: %d\n", pstSnsState->enWDRMode);
+		return CVI_FAILURE;
+	}
+
+
+	pstAeSnsDft->f32Fps = f32Fps;
+	pstAeSnsDft->u32LinesPer500ms = pstSnsState->u32FLStd * f32Fps / 2;
+	pstAeSnsDft->u32FullLinesStd = pstSnsState->u32FLStd;
+	pstAeSnsDft->u32MaxIntTime = pstSnsState->u32FLStd - 1;
+	pstSnsState->au32FL[0] = pstSnsState->u32FLStd;
+	pstAeSnsDft->u32FullLines = pstSnsState->au32FL[0];
+	pstAeSnsDft->u32HmaxTimes = (1000000) / (pstSnsState->u32FLStd * DIV_0_TO_1_FLOAT(f32Fps));
+
+	return CVI_SUCCESS;
+}
+
+static CVI_S32 cmos_inttime_update(VI_PIPE ViPipe, CVI_U32 *u32IntTime)
+{
+	ISP_SNS_STATE_S *pstSnsState = CVI_NULL;
+	ISP_SNS_REGS_INFO_S *pstSnsRegsInfo = CVI_NULL;
+	CVI_U32 u32Value = 0;
+
+	IMX577_SENSOR_GET_CTX(ViPipe, pstSnsState);
+	CMOS_CHECK_POINTER(pstSnsState);
+	CMOS_CHECK_POINTER(u32IntTime);
+	pstSnsRegsInfo = &pstSnsState->astSyncInfo[0].snsCfg;
+
+	if (WDR_MODE_NONE == pstSnsState->enWDRMode) {
+		u32Value = *u32IntTime;
+
+		pstSnsRegsInfo->astI2cData[LINEAR_SHR_L].u32Data = (u32Value & 0xFF);
+		pstSnsRegsInfo->astI2cData[LINEAR_SHR_H].u32Data = ((u32Value & 0xFF00) >> 8);
+	} else {
+		CVI_TRACE_SNS(CVI_DBG_ERR, "Unsupport wdr mode\n");
+		return CVI_FAILURE;
+	}
+
+	return CVI_SUCCESS;
+
+}
