From 569e752fc2b398a056f90d69b860511479019991 Mon Sep 17 00:00:00 2001
From: "shawn.wu" <shawn.wu@sophgo.com>
Date: Mon, 29 Sep 2025 14:47:15 +0800
Subject: [PATCH 5/5] [fix](mmc): fix gpt expend partition size

Change-Id: I66e5370bc78c6bcdfa4fbf077831ddf142dac1f5
---
 tools/common/image_tool/create_automount.py | 18 +++++++++++++-----
 1 file changed, 13 insertions(+), 5 deletions(-)
 mode change 100755 => 100644 tools/common/image_tool/create_automount.py

diff --git a/tools/common/image_tool/create_automount.py b/tools/common/image_tool/create_automount.py
old mode 100755
new mode 100644
index 30cd6e8a..c2a60097
--- a/tools/common/image_tool/create_automount.py
+++ b/tools/common/image_tool/create_automount.py
@@ -51,9 +51,16 @@ def genCase(case, out, parts, storage):
                 #        % (i + 1)
                 #    )
                 #    out.write("fi\n")
+                if p["label"] == "DATA":
+                    out.write("echo -e \"OK\\nFix\\n%s\\n100\\n\" | parted "
+                              "---pretend-input-tty %s unit %% "
+                              "resizepart %s 100\n"
+                              % (source[-1], source[:-2], source[-1]))
                 out.write("e2fsck -y %s\n" % source)
+                if p["label"] == "DATA":
+                    out.write("resize2fs %s\n" % (source))
                 out.write(
-                    "mount -t %s -o sync %s %s\n"
+                    "mount -t %s -o rw %s %s\n"
                     % (p["type"], source, p["mountpoint"])
                 )
                 out.write("if [ $? != 0  ]; then\n")
@@ -63,12 +70,13 @@ def genCase(case, out, parts, storage):
                 )
                 out.write("mke2fs -T %s %s\n" % (p["type"], source))
                 out.write(
-                    "mount -t %s -o sync %s %s\n"
+                    "mount -t %s -o rw %s %s\n"
                     % (p["type"], source, p["mountpoint"])
                 )
                 out.write("resize2fs %s\n" % (source))
                 out.write(
-                    "elif [ $DL_FLAG'h' == '0x50524F47''h' ] || [ -z $ENV_DLFLAG ] || [ $ENV_DLFLAG == 'prog' ]; then\n"
+                    "elif [ $DL_FLAG'h' == '0x50524F47''h' ] || "
+                    "[ -z $ENV_DLFLAG ] || [ $ENV_DLFLAG == 'prog' ]; then\n"
                 )
                 out.write("resize2fs %s\n" % (source))
                 out.write("fi\n")
@@ -89,7 +97,7 @@ def genCase(case, out, parts, storage):
                 out.write("mdev -s\n")
                 out.write("fi\n")
                 out.write(
-                    "mount -t ubifs -o sync %s %s\n"
+                    "mount -t ubifs -o rw %s %s\n"
                     % (source, p["mountpoint"])
                 )
                 out.write("if [ $? != 0  ]; then\n")
@@ -101,7 +109,7 @@ def genCase(case, out, parts, storage):
                     "ubimkvol /dev/ubi%d -N %s -m\n" % (ubi_cnt, p["label"])
                 )
                 out.write(
-                    "mount -t ubifs -o sync %s %s\n"
+                    "mount -t ubifs -o rw %s %s\n"
                     % (source, p["mountpoint"])
                 )
                 out.write("fi\n")
